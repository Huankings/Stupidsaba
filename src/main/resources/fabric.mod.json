{
  "schemaVersion": 1,
  "id": "stupid_express",
  "version": "${version}",
  "name": "Stupid Express",
  "description": "i love among us",
  "authors": [],
  "contact": {},
  "license": "MIT",
  "icon": "assets/stupid_express/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "pro.fazeclan.river.stupid_express.client.StupidExpressClient"
    ],
    "main": [
      "pro.fazeclan.river.stupid_express.StupidExpress"
    ],
    "cardinal-components": [
      "pro.fazeclan.river.stupid_express.constants.SEComponents"
    ],
    "voicechat": [
      "pro.fazeclan.river.stupid_express.voice.StupidExpressVoiceChatPlugin"
    ]
  },
  "custom": {
    "cardinal-components": [
      "stupid_express:doused",
      "stupid_express:cooldown",
      "stupid_express:convener_player",
      "stupid_express:convener_disguise",
      "stupid_express:convener_momentum",
      "stupid_express:lovers",
      "stupid_express:lovers_pairs",
      "stupid_express:dual_personality"
    ]
  },
  "mixins": [
    "stupid_express.mixins.json",
    {
      "config": "stupid_express.client.mixins.json",
      "environment": "client"
    },
    "stupid_express_compat.mixins.json"
  ],
  "depends": {
    "fabricloader": "*",
    "fabric": "*",
    "minecraft": "${minecraft_version}",
    "wathe": "*",
    "harpymodloader": "*",
    "fzzy_config": "*"
  }
}
